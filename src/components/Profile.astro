---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@/lib/utils";

interface Props extends HTMLAttributes<"div"> {
  name?: string;
  position?: string;
  description?: string;
}

const {
  class: className,
  name = "Faisal Muhammad",
  position = "Content Writer",
  description = "Some sort description about myself.",
  ...props
} = Astro.props;
---

<div {...props} class={cn("flex flex-col space-y-2", className)}>
  <h1 class="text-4xl font-bold">{name}</h1>
  <p class="text-foreground text-lg font-medium">{position}</p>
  <p>{description}</p>
</div>
