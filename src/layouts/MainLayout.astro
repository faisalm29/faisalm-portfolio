---
import BaseLayout from "./BaseLayout.astro";
import type { SEOProps } from "astro-seo";

interface Props extends SEOProps {}

const { ...props } = Astro.props;
---

<BaseLayout {...props}>
  <main
    class="mx-auto flex w-[60ch] max-w-full flex-col space-y-12 px-6 py-24 lg:w-[114ch] lg:flex-row lg:justify-between lg:gap-4 lg:space-y-0 lg:py-0"
  >
    <slot />
  </main>
</BaseLayout>
