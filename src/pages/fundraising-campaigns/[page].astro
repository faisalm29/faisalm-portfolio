---
import { FundraisingCampaignItem } from "@/components/FundraisingCampaignItem";
import { FundraisingCampaigns } from "@/components/sections/FundraisingCampaigns";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import type { PaginateFunction } from "astro";
import { getCollection } from "astro:content";
import { date } from "astro:schema";

interface PaginateProps {
  paginate: PaginateFunction;
}

export const getStaticPaths = async ({ paginate }: PaginateProps) => {
  const fundraisingCampaigns = await getCollection("fundraisingCampaign");

  return paginate(fundraisingCampaigns, {
    pageSize: 10,
  }).filter(({ params }) => params.page !== "1");
};

const { page } = Astro.props;
const { currentPage, data, lastPage, total, url } = page;
---

<ArticleLayout>
  <section>
    <FundraisingCampaigns fundraisingCampaigns={data} />
    <nav class="flex items-center justify-center gap-2">
      {
        url.first && currentPage > 2 && (
          <a href="/social-media-contents">First</a>
        )
      }
      {url.prev && <a href={url.prev}>Previous</a>}
      {total > 1 && <span>{currentPage}</span>}
      {url.next && currentPage < lastPage && <a href={url.next}>Next</a>}
      {url.last && <a href={url.last}>Last</a>}
    </nav>
  </section>
</ArticleLayout>
