---
import { getCollection } from "astro:content";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { FundraisingCampaigns } from "@/components/sections/FundraisingCampaigns";
import { Badge } from "@/components/Badge";
import { Button } from "@/components/Button";
import { Icon } from "astro-icon/components";
import { getImage } from "astro:assets";
import defaultOg from "../../../public/og-fundraising-campaign-default.jpg";

const fundraisingCampaigns = (await getCollection("fundraisingCampaign")).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);

const pageSize = 10;
const firstPageFundraisingCampaigns = fundraisingCampaigns.slice(0, pageSize);
const totalPages = Math.ceil(fundraisingCampaigns.length / pageSize);

const defaultOgImage = await getImage({
  src: defaultOg,
  format: "jpeg",
});

const ogImageURL = new URL(defaultOgImage.src, Astro.url.origin).href;
---

<ArticleLayout
  title="Fundraising Campaigns"
  description="Fundraising campaign archives."
  openGraph={{
    basic: {
      image: ogImageURL,
      title: "Fundraising Campaigns",
      type: "website",
    },
  }}
>
  <section class="flex flex-col space-y-4">
    <div>
      <Button variant="outline" as="a" href="/" className="group"
        ><Icon
          name="arrow-left"
          class="mr-1 transition-all duration-300 ease-in-out group-hover:-translate-x-1.5"
        />Back</Button
      >
    </div>
    <FundraisingCampaigns
      fundraisingCampaigns={firstPageFundraisingCampaigns}
    />

    <nav class="flex items-center justify-center gap-2">
      {
        fundraisingCampaigns.length > pageSize && (
          <Badge variant="outline" size="sm">
            1
          </Badge>
        )
      }
      {
        totalPages > 1 && (
          <Button
            as="a"
            variant="outline"
            size="sm"
            href="/fundraising-campaigns/2"
          >
            Next
          </Button>
        )
      }
      {
        totalPages > 1 && (
          <Button
            as="a"
            variant="outline"
            size="sm"
            href={`/fundraising-campaigns/${String(totalPages)}`}
          >
            Last
          </Button>
        )
      }
    </nav>
  </section>
</ArticleLayout>
