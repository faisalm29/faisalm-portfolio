---
import { getCollection } from "astro:content";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { Articles } from "@/components/sections/Articles";
import { getAllArticles, sortArticles } from "@/lib/utils";
import { Badge } from "@/components/Badge";
import { Button } from "@/components/Button";
import { Icon } from "astro-icon/components";
import { getImage } from "astro:assets";
import defaultOg from "../../../public/og-article-default.jpg";

const articles = sortArticles(await getAllArticles());

const pageSize = 10;
const firstPageArticles = articles.slice(0, pageSize);
const totalPages = Math.ceil(articles.length / pageSize);

const defaultOgImage = await getImage({
  src: defaultOg,
  format: "jpeg",
});

const ogImageURL = new URL(defaultOgImage.src, Astro.url.origin).href;
---

<ArticleLayout
  title="Articles"
  description="Article archives."
  openGraph={{
    basic: {
      image: ogImageURL,
      title: "Articles",
      type: "website",
    },
  }}
>
  <section class="flex flex-col space-y-4">
    <div>
      <Button variant="outline" as="a" href="/" className="group"
        ><Icon
          name="arrow-left"
          class="mr-1 transition-all duration-300 ease-in-out group-hover:-translate-x-1.5"
        />Back</Button
      >
    </div>
    <Articles articles={firstPageArticles} />
    <nav class="flex items-center justify-center gap-2">
      {
        articles.length > pageSize && (
          <Badge variant="outline" size="sm">
            1
          </Badge>
        )
      }
      {
        totalPages > 1 && (
          <Button as="a" variant="outline" size="sm" href="/articles/2">
            Next
          </Button>
        )
      }
      {
        totalPages > 1 && (
          <Button
            as="a"
            variant="outline"
            size="sm"
            href={`/articles/${String(totalPages)}`}
          >
            Last
          </Button>
        )
      }
    </nav>
  </section>
</ArticleLayout>
